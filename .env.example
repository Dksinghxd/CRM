# Environment Variables — SmartReach AI CRM
# Copy this file to .env and fill in your values

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=smartreach
POSTGRES_PASSWORD=smartreach_pass
POSTGRES_DB=smartreach_crm
DATABASE_URL=postgresql://smartreach:smartreach_pass@localhost:5432/smartreach_crm

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Backend ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Channel Service ──────────────────────────────────────────────────────────
CHANNEL_SERVICE_URL=http://localhost:5000
CHANNEL_PORT=5000
BACKEND_CALLBACK_URL=http://localhost:4000/api/channel/receipt

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
